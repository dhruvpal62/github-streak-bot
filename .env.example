# Runtime
NODE_ENV=production
BOT_TIMEZONE=Asia/Kolkata
DRY_RUN=false
MAX_DAILY_COMMITS=1
RANDOM_DELAY_MINUTES=45

# Git identity used by GitHub Actions commits
GIT_AUTHOR_NAME=github-streak-bot
GIT_AUTHOR_EMAIL=github-streak-bot@users.noreply.github.com

# GitHub authentication
GITHUB_TOKEN=your_github_token
GITHUB_OWNER=your_github_username
GITHUB_REPOSITORY=your_repository_name
GITHUB_BRANCH=main

# Optional multi-repository publishing
TARGET_REPOSITORIES=[]

# Optional AI provider
AI_PROVIDER=none
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Optional notifications
DISCORD_WEBHOOK_URL=your_discord_webhook
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Optional GitHub issue creation on repeated failures
CREATE_ISSUE_ON_FAILURE=false
FAILURE_ISSUE_LABELS=automation,bug